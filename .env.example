# Copy this file to .env and adjust as needed. .env is gitignored.

POSTGRES_DB=inventorysystem
POSTGRES_USER=inventorysystem
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Used by docker-compose.prod.yml only.
# Caddy serves the frontend and backend from the same origin (see Caddyfile),
# so VITE_API_BASE_URL can just be a relative path - no domain needed in it.
FRONTEND_ORIGIN=https://inventory.midnightmariner.com
VITE_API_BASE_URL=/api
